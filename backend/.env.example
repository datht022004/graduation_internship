# === LLM Provider ===
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# Keep only if LLM_PROVIDER=google or Google login is enabled.
GOOGLE_API_KEY=

# === Model Settings ===
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
LLM_MODEL=gpt-4.1-mini
RAG_TOP_K=4
VECTOR_INDEX_NAME=vector_index

# === MongoDB ===
APP_MONGODB_URI=mongodb://localhost:27017/?directConnection=true
VECTOR_MONGODB_URI=mongodb://localhost:27017/?directConnection=true
MONGODB_DB_NAME=rag_chatbot

# === Storage ===
UPLOAD_DIR=./data/documents

# === Chunking ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# === Auth ===
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=123123
USER_EMAIL=user@gmail.com
USER_PASSWORD=123123
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# === Upload ===
MAX_FILE_SIZE_MB=100
